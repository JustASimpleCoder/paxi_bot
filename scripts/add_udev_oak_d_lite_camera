
# got from: docs.luxonis.com/hardware/platform/deploy/usb-deployment-guide/
echo 'If error persist run as sudo'


echo 'SUBSYSTEM=="usb", ATTRS{idVendor}=="03e7", MODE="0666"' | sudo tee /etc/udev/rules.d/80-movidius.rules

sudo udevadm control --reload-rules && 
sudo udevadm trigger


echo 'Plug in oak d lite camera, you should be able to run:'
echo ' lsusb | grep 03e7'
echo ''
echo 'You should see Output '
echo ' Bus xxx Device xxx: ID 03e7:2485 Intel Movidius MyriadX'
